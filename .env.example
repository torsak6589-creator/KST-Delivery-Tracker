# ── Database connection ─────────────────────────────────────────────
# SQL Server (default — matches a typical SAP Business One / company MSSQL):
DATABASE_URL="sqlserver://HOST:1433;database=KST_TRACKER;user=USER;password=PASSWORD;encrypt=true;trustServerCertificate=true"

# MySQL example (set provider="mysql" in prisma/schema.prisma):
# DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/KST_TRACKER"

# PostgreSQL example (set provider="postgresql" in prisma/schema.prisma):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/KST_TRACKER?schema=public"

# Snapshot reference date for status calculation (used if AppMeta is empty)
NEXT_PUBLIC_SNAPSHOT_DATE="2026-06-24"
